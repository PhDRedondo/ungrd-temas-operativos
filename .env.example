# App
AUTH_MODE=demo
NEXT_PUBLIC_AUTH_MODE=demo
AUTH_SECRET=ungrd-dev-secret-change-me-in-prod
DATABASE_URL=postgresql://ungrd:ungrd@127.0.0.1:5432/ungrd_temas
AUTH_URL=http://localhost:3000

# ACL: false = sin filas ACL → acceso amplio (ideal local)
# true = sin filas ACL → sin acceso (ideal Vercel/prod)
ACL_STRICT=false

# ── Seguridad (protocolo v1) ──────────────────────────────────
SECURITY_ENABLED=true
SECURITY_TRUST_PROXY=true
# En local, localhost queda en allowlist (rate laxo). En prod: false
SECURITY_ALLOW_LOCALHOST=true
SECURITY_API_RPM=180
SECURITY_AUTH_RPM=40
SECURITY_UPLOAD_RPM=20
SECURITY_HEALTH_RPM=30
SECURITY_WINDOW_MS=60000
SECURITY_BAN_THRESHOLD=20
SECURITY_BAN_MS=900000
SECURITY_MAX_BODY_MB=12

# ── Vercel / producción (configurar en el dashboard, NO en git) ──
# AUTH_URL=https://tu-app.vercel.app
# AUTH_SECRET=<generar-secreto-largo>
# ACL_STRICT=true
# SECURITY_ALLOW_LOCALHOST=false
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-….pooler.supabase.com:6543/postgres
# NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<solo-server-nunca-NEXT_PUBLIC>

# Keycloak (cuando AUTH_MODE=keycloak)
# KEYCLOAK_CLIENT_ID=ungrd-app
# KEYCLOAK_CLIENT_SECRET=ungrd-app-secret-change-me
# KEYCLOAK_ISSUER=http://localhost:8080/realms/ungrd
# AUTH_MODE=keycloak
# NEXT_PUBLIC_AUTH_MODE=keycloak
