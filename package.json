{
  "name": "ungrd-app",
  "version": "0.1.0",
  "private": true,
  "description": "UNGRD Temas Operativos — captura, Excel DIVIPOLA y analítica geoespacial",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:unit": "tsx scripts/test-upload-pipeline.ts && tsx scripts/test-national-analytics.ts && tsx scripts/test-record-filters.ts && tsx scripts/test-theme-briefing-pdf.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "db:setup": "drizzle-kit push && tsx src/db/seed.ts",
    "db:platform-migrate": "psql \"$DATABASE_URL\" -f drizzle/migrations/0001_platform_schemas.sql",
    "db:platform-seed": "tsx src/db/seed-platform.ts",
    "db:platform": "npm run db:platform-migrate && npm run db:platform-seed",
    "db:official-setup": "tsx scripts/db/setup-official.ts",
    "db:reimport": "tsx scripts/prep-reimport-all.ts",
    "prep:deploy": "npm run typecheck && npm run build && echo 'OK build — ver docs/DEPLOY.md'",
    "harness": "tsx scripts/harness/run.ts",
    "harness:env": "tsx scripts/harness/check-env.ts",
    "harness:back": "tsx scripts/harness/check-back.ts",
    "harness:platform": "tsx scripts/harness/check-platform.ts",
    "harness:front": "tsx scripts/harness/check-front.ts",
    "harness:security": "tsx scripts/harness/check-security.ts",
    "smoke": "tsx scripts/smoke-local.ts",
    "ci:local": "npm run lint && npm run typecheck && npm run smoke",
    "geo:refresh": "curl -sL \"https://www.datos.gov.co/resource/gdxc-w37w.json?\\$limit=50000\" -o data/divipola-municipios.raw.json && echo 'Raw OK — regenerar divipola.json con el script en data/README.md'",
    "stack:up": "docker compose up -d",
    "stack:down": "docker compose down",
    "docs:open": "echo 'Ver docs/README.md'"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "d3-sankey": "^0.12.3",
    "d3-shape": "^3.2.0",
    "driver.js": "^1.7.0",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.9.2",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/d3-force": "^3.0.10",
    "@types/d3-sankey": "^0.12.5",
    "@types/d3-shape": "^3.1.8",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
